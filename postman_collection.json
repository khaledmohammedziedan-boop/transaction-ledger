{
  "info": {
    "name": "Transaction Ledger API",
    "description": "Example requests for the Transaction Ledger service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/transaction-ledger"
    },
    {
      "key": "jwt",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Khaled Saleh\",\n  \"email\": \"khaled@example.com\",\n  \"mobileNumber\": \"+962790000000\",\n  \"pwd\": \"P@ssw0rd!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a new user account."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.jwtToken) {",
                  "  pm.collectionVariables.set('jwt', response.jwtToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"khaled@example.com\",\n  \"password\": \"P@ssw0rd!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/apiLogin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "apiLogin"
              ]
            },
            "description": "Authenticates a user and stores the returned JWT in the collection variable `jwt`."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "user"
              ]
            },
            "description": "Returns profile information for the authenticated user."
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 150.75,\n  \"currency\": \"EUR\",\n  \"description\": \"Grocery purchase\",\n  \"counterPartyIban\": \"DE44500105175407324931\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transaction",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transaction"
              ]
            },
            "description": "Creates a transaction owned by the authenticated user."
          }
        },
        {
          "name": "List Transactions",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transaction/getTransactionsPage?page=0&size=20&filter=amount,GT,100&sort=createdAt,DESC",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transaction",
                "getTransactionsPage"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                },
                {
                  "key": "filter",
                  "value": "amount,GT,100"
                },
                {
                  "key": "sort",
                  "value": "createdAt,DESC"
                }
              ]
            },
            "description": "Returns a paginated transaction list for the authenticated user."
          }
        }
      ]
    }
  ]
}
